# ========================================
# POÉSIE-MR Environment Configuration
# ========================================
# Copy this file to .env and customize

# ========== DJANGO ==========
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,*.poetry-mr.local
ENVIRONMENT=development

# ========== DATABASE ==========
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=poetry_mr_dev
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Alternatively use DATABASE_URL
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/poetry_mr_dev

# ========== CACHE & SESSION ==========
REDIS_URL=redis://localhost:6379/0
CACHE_TIMEOUT=300  # 5 minutes
SESSION_ENGINE=django.contrib.sessions.backends.cache

# ========== CELERY ==========
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_ACCEPT_CONTENT=json
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC

# ========== EMAIL (Mailhog for dev) ==========
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=noreply@poetry-mr.local

# Production email (SendGrid / Brevo)
# EMAIL_BACKEND=sendgrid_backend.SendgridBackend
# SENDGRID_API_KEY=sg_xxxxx
# SENDGRID_SANDBOX_MODE_IN_DEBUG=False

# ========== STORAGE ==========
USE_S3=False  # Set to True for production S3
STORAGE_BACKEND=django.core.files.storage.FileSystemStorage

# MinIO/S3 Configuration (if USE_S3=True)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_HTTPS=False

# ========== CORS & Security ==========
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True

# ========== Authentication ==========
JWT_SECRET_KEY=your-jwt-secret-key
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7
AUTH_PASSWORD_VALIDATORS=django.contrib.auth.password_validation.UserAttributeSimilarityValidator,django.contrib.auth.password_validation.MinimumLengthValidator

# ========== Payment Gateway ==========
# Bankily
BANKILY_MERCHANT_ID=your_merchant_id
BANKILY_API_KEY=your_api_key
BANKILY_ENVIRONMENT=sandbox  # sandbox or production

# Sedad
SEDAD_MERCHANT_ID=your_merchant_id
SEDAD_API_KEY=your_api_key

# Masrivi
MASRIVI_MERCHANT_ID=your_merchant_id
MASRIVI_API_KEY=your_api_key

# Bimbank
BIMBANK_MERCHANT_ID=your_merchant_id
BIMBANK_API_KEY=your_api_key

# Stripe Connect (for international)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# ========== SMS & Notifications ==========
# Twilio (WhatsApp + SMS)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+22260000000
TWILIO_WHATSAPP_PHONE_NUMBER=whatsapp:+22260000000

# ========== AWS (Optional) ==========
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_STORAGE_BUCKET_NAME=poetry-mr-assets
AWS_S3_REGION_NAME=eu-west-1

# ========== Logging ==========
LOG_LEVEL=DEBUG
LOG_FILE=/var/log/poetry-mr/app.log

# ========== Frontend ==========
FRONTEND_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:8000
VITE_API_TIMEOUT=30000
VITE_DEFAULT_LANGUAGE=fr
VITE_ENVIRONMENT=development
